{
	"appId": "com.vibegram.app",
	"appName": "Vibegram",
	"webDir": "dist",
	"server": {
		"androidScheme": "https",
		"cleartext": true,
		"allowNavigation": [
			"*"
		]
	},
	"plugins": {
		"CapacitorHttp": {
			"enabled": true
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound"
			]
		}
	}
}
